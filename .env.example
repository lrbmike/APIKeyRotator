# ===============================================================
#                API Key Rotator Configuration
# ===============================================================

# ---------------------------------------------------------------
# Required Settings
# These variables MUST be set for the application to run.
# ---------------------------------------------------------------

# Administrator password for the web interface.
ADMIN_PASSWORD=your_strong_password_here

# Secret key for signing JWT tokens. Use a long, random string for security.
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your_very_secret_and_random_jwt_key

# Global keys for authenticating proxy requests.
# Any request to the proxy endpoints must include one of these keys in the 'X-Proxy-Key' header.
# Supports a single key or multiple keys (comma-separated).
# Example (single key): GLOBAL_PROXY_KEYS=a_very_secret_key
# Example (multiple keys): GLOBAL_PROXY_KEYS=key1,key2,key3
GLOBAL_PROXY_KEYS=your_secure_global_proxy_key

# ---------------------------------------------------------------
# Optional Settings
# These variables have default values and can be omitted.
# ---------------------------------------------------------------

# Administrator username for the web interface.
# Default: admin
ADMIN_USER=admin

# Path to the SQLite database file.
# Default: ./data/api_key_rotator.db
DATABASE_PATH=./data/api_key_rotator.db

# Port on which the backend server will run.
# Default: 8000
BACKEND_PORT=8000

# Publicly accessible base URL for the proxy service.
# This is used to generate the full proxy URLs in the UI.
# Default: http://localhost:8000
PROXY_PUBLIC_BASE_URL=http://localhost:8000

# Timeout in seconds for requests made by the proxy to the target APIs.
# Default: 30
PROXY_TIMEOUT=30

# Log level for the application.
# Can be: debug, info, warn, error
# Default: info
LOG_LEVEL=info
